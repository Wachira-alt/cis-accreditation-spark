{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/server.js": {
      "includeFiles": "dist/server/**"
    }
  },
  "rewrites": [
    { "source": "/((?!assets/|images/|favicon|.*\\..*).*)", "destination": "/api/server" }
  ]
}
